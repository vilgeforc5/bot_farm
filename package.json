{
  "name": "bot-farm-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker,dashboard -c blue,magenta,green \"bun run dev:api\" \"bun run dev:worker\" \"bun run dev:dashboard\"",
    "dev:api": "bun --filter @bot-farm/server dev:api",
    "dev:worker": "bun --filter @bot-farm/server dev:worker",
    "dev:dashboard": "bun --filter @bot-farm/dashboard dev",
    "build": "bun run check",
    "check:server": "bun --filter @bot-farm/server check",
    "check:dashboard": "bun --filter @bot-farm/dashboard build",
    "check": "bun run check:server && bun run check:dashboard",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "pm2": "^6.0.8",
    "@tanstack/react-table": "^8.21.3"
  }
}
