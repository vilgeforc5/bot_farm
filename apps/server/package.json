{
  "name": "@bot-farm/server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run dev:api",
    "dev:api": "bun run --watch src/index.ts",
    "dev:worker": "bun run --watch src/worker.ts",
    "start": "bun run src/index.ts",
    "start:worker": "bun run src/worker.ts",
    "test": "vitest run",
    "check": "bun run typecheck",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openrouter/sdk": "^0.9.11",
    "grammy": "^1.41.1",
    "hono": "^4.12.5",
    "reflect-metadata": "^0.2.2",
    "sql.js": "^1.13.0",
    "typeorm": "^0.3.26",
    "world-countries": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
