APP_PORT=3001
# In production set this to your public HTTPS URL (no trailing slash)
# Telegram will POST updates to: APP_BASE_URL/webhooks/telegram/<slug>
APP_BASE_URL=http://localhost:3001
DB_ADAPTER=typeorm
DB_PATH=./data/bot-farm.sqlite
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_OPENROUTER_MODEL=openrouter/free
DEFAULT_CONTEXT_LIMIT=300
# Set to false in production — webhooks are used instead
DEV_LONG_POLLING=true
TELEGRAM_POLL_TIMEOUT_SECONDS=25
SECRET_ENCRYPTION_KEY=change-me
DASHBOARD_ORIGIN=http://localhost:3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin
# Path to the self-signed TLS cert (PEM). Required when APP_BASE_URL uses a
# self-signed cert so the server can upload it to Telegram during bot connect.
# Leave empty if you use a CA-signed cert (e.g. Let's Encrypt).
# WEBHOOK_CERT_PATH=/app/certs/cert.pem
